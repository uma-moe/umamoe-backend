# Copy this file to the server as:
#   /opt/umamoe-backend/prod.env
#   /opt/umamoe-backend/beta.env
#
# The GitHub workflow injects HOST, PORT, DEBUG_MODE, and the unpublished internal proof port at `docker run` time.
# It also syncs deploy/backend.compose.yml and starts Redis with `--no-recreate`.

DATABASE_URL=postgresql://user:password@host:5432/umamoe

ALLOWED_ORIGINS=https://uma.moe,https://www.uma.moe,https://beta.uma.moe
FRONTEND_URL=https://uma.moe
OAUTH_REDIRECT_BASE_URL=https://api.uma.moe
# Internal-only auth verifier/proof API. Keep this unpublished on the shared Docker network.
INTERNAL_API_HOST=0.0.0.0
INTERNAL_API_PORT=3201
# Use the Docker container name and internal x200 port on the shared network.
# Beta should use http://umamoe-search-beta:3202.
SEARCH_SERVICE_URL=http://umamoe-search:3202

JWT_SECRET=change-me
BROWSER_PROOF_SECRET=change-me-too
# Optional when API/search/resources are served from different subdomains.
# BROWSER_PROOF_COOKIE_DOMAIN=.uma.moe

# Redis is provided by deploy/backend.compose.yml on the shared Docker network.
REDIS_URL=redis://redis:6379/0
REDIS_KEY_PREFIX=umamoe

TURNSTILE_SECRET_KEY=change-me
TURNSTILE_ALLOWED_HOSTS=uma.moe,www.uma.moe,beta.uma.moe
TURNSTILE_ACTION=api_request
# Local-only: accepted only when DEBUG_MODE=true. Lets ng serve test proof exchange without Cloudflare.
# TURNSTILE_DEV_TOKEN=local-dev-turnstile-token
API_BROWSER_BOOTSTRAP_READS_PER_MINUTE=6
BROWSER_PROOF_TTL_SECONDS=300
BROWSER_PROOF_WARMUP_BURST=4
BROWSER_PROOF_WARMUP_LOCK_SECONDS=120
# Run protection checks and log allow/reject decisions, but do not block requests.
# Useful with API_PROTECTION_BYPASS=true during prod rollout validation.
API_PROTECTION_DRY_RUN=false
API_PROTECTION_BYPASS=false
TURNSTILE_BYPASS=false

SKIP_MIGRATIONS=false
# Set true on beta/prod if this instance must run migrations, materialized
# view refreshes, or analysis aggregate writes and should fail fast on a
# read-only replica/session.
REQUIRE_WRITABLE_DATABASE=false

# Set true on beta/staging followers that must not create or mutate replicated
# user/task/profile/usage tables. Backend-generated aggregates still run.
USER_WRITES_DISABLED=false

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
APPLE_CLIENT_ID=
APPLE_CLIENT_SECRET=
